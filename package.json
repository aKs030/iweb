{
  "name": "aks-website",
  "version": "1.0.0",
  "description": "Portfolio Website mit Cloudflare Pages Functions (Vanilla JS)",
  "private": true,
  "type": "module",
  "author": "Abdulkerim Sesli <kontakt@abdulkerimsesli.de>",
  "homepage": "https://www.abdulkerimsesli.de",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.6.0",
    "husky": "^9.0.0",
    "jscpd": "4.2.2",
    "lint-staged": "^15.0.0",
    "prettier": "3.8.3",
    "wrangler": "4.92.0"
  },
  "scripts": {
    "dev": "wrangler pages dev . --port 8787 --show-interactive-dev-session=false",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint content pages functions --fix",
    "lint:css": "prettier --write \"content/**/*.css\" \"pages/**/*.css\"",
    "analyze:duplicates": "jscpd --min-lines 8 --min-tokens 80 --format javascript,css --reporters console content pages content/styles",
    "clean": "rm -rf .wrangler .jscpd .eslintcache",
    "format": "prettier --write \"content/**/*.{js,json,md}\" \"pages/**/*.{js,json,md}\" \"functions/**/*.js\"",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.js": "eslint --fix",
    "*.{json,md}": "prettier --write",
    "*.css": "prettier --write"
  }
}
