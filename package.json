{
  "name": "iweb",
  "version": "1.0.0",
  "description": "Abdulkerims persönliche Website – modern, responsive und DSGVO-konform",
  "main": "index.html",
  "scripts": {
    "dev": "python -m http.server 8000",
    "dev-node": "npx http-server -p 8000 -c-1",
    "build": "echo 'Static site – no build needed'",
    "validate-html": "html-validate index.html pages/**/*.html",
    "validate-css": "stylelint css/**/*.css",
    "lighthouse": "lighthouse http://localhost:8000 --output=html --output-path=./lighthouse-report.html",
    "test-performance": "node scripts/performance-test.js",
    "compress-images": "imagemin img/**/*.{jpg,png} --plugin=mozjpeg --plugin=optipng --out-dir=img/optimized",
    "check-links": "broken-link-checker http://localhost:8000",
    "deploy-check": "npm run validate-html && npm run validate-css && npm run check-links"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aKs030/iweb.git"
  },
  "keywords": [
    "personal-website",
    "responsive",
    "pwa",
    "gdpr",
    "accessibility",
    "performance"
  ],
  "author": "Abdulkerim",
  "license": "MIT",
  "devDependencies": {
    "broken-link-checker": "^0.6.7",
    "html-validate": "^8.0.0",
    "http-server": "^14.0.0",
    "imagemin": "^8.0.1",
    "imagemin-mozjpeg": "^9.0.0",
    "imagemin-optipng": "^9.0.0",
    "lighthouse": "^12.8.0",
    "stylelint": "^15.0.0",
    "stylelint-config-standard": "^34.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "engines": {
    "node": ">=16.0.0"
  }
}