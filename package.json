{
  "name": "iweb",
  "version": "1.0.0",
  "description": "Abdulkerims persönliche Website – modern, responsive, DSGVO-konform",
  "main": "index.html",
  "scripts": {
    "dev": "node scripts/dev-server.js",
    "start": "node scripts/dev-server.js",
    "dev-node": "node scripts/dev-server.js",
    "build": "echo '✅ Static site – no build step needed'",
    "validate-html": "html-validate index.html pages/**/*.html",
    "validate-css": "stylelint css/**/*.css",
    "check-links": "linkinator http://localhost:8000 --recurse --skip-external true",
    "check-links-local": "lsof -i :8000 | grep LISTEN > /dev/null && npm run check-links || (node scripts/dev-server.js & SERVER_PID=$!; sleep 5; npm run check-links; kill $SERVER_PID)",
    "lighthouse": "lighthouse http://localhost:8000 --output html --output-path ./lighthouse-report.html",
    "test-performance": "node scripts/performance-test.js",
    "compress-images": "imagemin img/**/*.{jpg,png} --out-dir=img/optimized",
    "optimize:images": "sharp-cli img/**/*.{jpg,png} --output=img/optimized --webp --avif",
    "purge": "mkdir -p css/purged && purgecss --css css/*.css --content pages/**/*.html js/**/*.js --output css/purged/",
    "optimize": "npm run compress-images && npm run purge",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint \"js/**/*.js\" --fix",
    "lint:check": "eslint \"js/**/*.js\"",
    "security-audit": "audit-ci --moderate --exit-code 1",
    "security-check": "node scripts/check-security-headers.js",
    "security-check:prod": "node scripts/check-security-headers.js https://abdulkerimsesli.de",
    "pre-deploy": "npm run format && npm run lint && npm run validate-html && npm run validate-css && npm run optimize",
    "test": "npm run validate-html && npm run validate-css"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@lhci/cli": "^0.15.1",
    "@percy/cli": "1.31.1",
    "audit-ci": "^7.1.0",
    "cssnano": "^7.1.0",
    "eslint": "^9.31.0",
    "eslint-plugin-react": "^7.37.5",
    "express": "5.1.0",
    "globals": "^16.3.0",
    "html-validate": "9.7.1",
    "jest": "^30.0.4",
    "lighthouse": "^12.8.0",
    "linkinator": "^6.1.4",
    "prettier": "^3.6.2",
    "purgecss": "7.0.2",
    "sharp-cli": "^5.2.0",
    "stylelint": "16.22.0",
    "stylelint-config-standard": "38.0.0",
    "terser": "^5.43.1",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.0.5"
  },
  "dependencies": {
    "firebase": "^12.0.0",
    "puppeteer": "24.14.0",
    "puppeteer-core": "24.14.0",
    "webdriverio": "9.18.1"
  },
  "overrides": {
    "cross-spawn": "6.0.6",
    "http-cache-semantics": "4.1.1",
    "nth-check": "2.0.1",
    "semver-regex": "3.1.4",
    "trim-newlines": "3.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "keywords": [
    "personal-website",
    "responsive",
    "pwa",
    "gdpr",
    "accessibility",
    "performance"
  ],
  "author": "Abdulkerim",
  "license": "MIT"
}
