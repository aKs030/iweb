{
  "name": "aks-website",
  "version": "1.0.0",
  "description": "Portfolio Website mit Cloudflare Pages Functions (Vanilla JS)",
  "private": true,
  "type": "module",
  "author": "Abdulkerim Sesli <kontakt@abdulkerimsesli.de>",
  "homepage": "https://www.abdulkerimsesli.de",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "simple-git-hooks": "^2.13.1",
    "wrangler": "^4.107.0"
  },
  "scripts": {
    "dev": "wrangler pages dev . --port 8787 --show-interactive-dev-session=false",
    "prepare": "simple-git-hooks",
    "lint:staged": "lint-staged",
    "lint:fix": "npm exec --yes -- eslint --fix",
    "format:file": "npm exec --yes -- prettier --write",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check:format": "prettier --check .",
    "check:lint": "eslint . --max-warnings=0",
    "build": "echo \"No build configured (project runs without bundling)\"",
    "build:css": "echo \"No CSS build configured\""
  },
  "lint-staged": {
    "*.{js,mjs}": [
      "npm run -s lint:fix --",
      "npm run -s format:file --"
    ],
    "*.{json,md,css,html,xml,svg,yml,yaml}": "npm run -s format:file --"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run -s lint:staged"
  },
  "prettier": {
    "trailingComma": "es5",
    "printWidth": 100,
    "arrowParens": "avoid",
    "endOfLine": "lf",
    "overrides": [
      {
        "files": "*.jsonld",
        "options": {
          "parser": "json"
        }
      }
    ]
  }
}
