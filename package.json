{
  "name": "aks-website",
  "version": "1.0.0",
  "description": "Portfolio Website mit Cloudflare AI Search (Vanilla JS)",
  "private": true,
  "type": "module",
  "keywords": [
    "portfolio",
    "three.js",
    "cloudflare-pages",
    "ai-search",
    "rag",
    "web-components",
    "vanilla-javascript",
    "zero-build",
    "edge-computing",
    "webgl",
    "performance"
  ],
  "author": {
    "name": "Abdulkerim Sesli",
    "email": "kontakt@abdulkerimsesli.de",
    "url": "https://www.abdulkerimsesli.de"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aKs030/iweb.git"
  },
  "homepage": "https://www.abdulkerimsesli.de",
  "bugs": {
    "url": "https://github.com/aKs030/iweb/issues",
    "email": "kontakt@abdulkerimsesli.de"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "node scripts/dev-workflow.mjs",
    "build": "echo 'Zero-build architecture - no build step needed'",
    "start": "npm run dev",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "run-s test:*",
    "test:unit": "node --test tests/*.test.mjs",
    "test:browser": "node scripts/browser-smoke.mjs",
    "lint": "run-p lint:*",
    "lint:es": "eslint . --cache",
    "lint:css": "stylelint \"**/*.css\" --cache --ignore-path .gitignore",
    "lint:format": "prettier --check .",
    "fix": "run-p fix:*",
    "fix:es": "eslint . --fix --cache",
    "fix:css": "stylelint \"**/*.css\" --fix --cache --ignore-path .gitignore",
    "fix:format": "prettier --write .",
    "format": "npm run fix:format",
    "format:check": "npm run lint:format",
    "check": "run-s check:*",
    "check:structure": "node scripts/structure-check.mjs",
    "check:tokens": "node scripts/css-token-structure-check.mjs",
    "check:importmap": "node scripts/sync-import-map.mjs --check",
    "check:ai": "node scripts/sync-ai-index-apps.mjs --check",
    "check:docs": "node scripts/docs-check.mjs",
    "check:typecheck": "npm run typecheck",
    "sync": "run-p sync:*",
    "sync:importmap": "node scripts/sync-import-map.mjs",
    "sync:ai": "node scripts/sync-ai-index-apps.mjs",
    "sync:content-rag": "node scripts/sync-content-rag.mjs",
    "admin:maintenance": "node scripts/admin-maintenance.mjs",
    "eval:content-rag": "node scripts/evaluate-content-rag.mjs",
    "setup:content-rag-index": "node scripts/setup-content-rag-index.mjs",
    "sync:styles": "run-s sync:styles:*",
    "sync:styles:tokens": "node scripts/generate-tokens-css.mjs",
    "sync:styles:utilities": "node scripts/generate-utilities.mjs",
    "qa": "run-s fix lint check",
    "clean": "run-p clean:*",
    "clean:cache": "rm -rf node_modules/.cache .eslintcache .stylelintcache .prettiercache",
    "clean:wrangler": "rm -rf .wrangler",
    "prepare": "husky",
    "preinstall": "npx only-allow npm",
    "postinstall": "echo '✅ Dependencies installed successfully'"
  },
  "dependencies": {
    "htm": "^3.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "25.4.0",
    "eslint": "10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "16.4.0",
    "npm-run-all2": "^8.0.4",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "stylelint": "17.5.0",
    "typescript": "5.9.3",
    "wrangler": "4.76.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{md,html,json,jsonc,yml,yaml}": [
      "prettier --write"
    ]
  }
}
