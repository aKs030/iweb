{
  "name": "aks-website",
  "version": "1.0.0",
  "description": "No-Build-Portfolio mit Cloudflare Pages Functions, React und Web Components",
  "private": true,
  "type": "module",
  "author": "Abdulkerim Sesli <kontakt@abdulkerimsesli.de>",
  "homepage": "https://www.abdulkerimsesli.de",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "simple-git-hooks": "^2.13.1",
    "wrangler": "^4.110.0"
  },
  "scripts": {
    "dev": "wrangler pages dev . --port 8787 --show-interactive-dev-session=false",
    "db:migrate:local": "wrangler d1 migrations apply DB_LIKES --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB_LIKES --remote",
    "types": "wrangler types worker-configuration.d.ts --include-runtime false --strict-vars true",
    "types:check": "wrangler types worker-configuration.d.ts --include-runtime false --strict-vars true --check",
    "check:budgets": "node scripts/check-performance-budgets.mjs",
    "prepare": "simple-git-hooks",
    "lint:staged": "lint-staged",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check:format": "prettier --check ."
  },
  "lint-staged": {
    "*.{js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,xml,svg,yml,yaml}": "prettier --write"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run -s lint:staged"
  },
  "prettier": {
    "trailingComma": "es5",
    "printWidth": 100,
    "arrowParens": "avoid",
    "endOfLine": "lf",
    "overrides": [
      {
        "files": "*.jsonld",
        "options": {
          "parser": "json"
        }
      }
    ]
  }
}
