{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "useDefineForClassFields": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "#core/*": ["content/core/*"],
      "#components/*": ["content/components/*"],
      "#footer/*": ["content/components/footer/*"],
      "#menu/*": ["content/components/menu/*"],
      "#config/*": ["content/config/*"],
      "#pages/*": ["pages/*"],
      "/content/*": ["content/*"],
      "/pages/*": ["pages/*"]
    }
  },
  "include": ["content/**/*.js", "pages/**/*.js", "sw.js"],
  "exclude": [
    "node_modules",
    "reports",
    "functions",
    "scripts",
    "worker-configuration.d.ts"
  ]
}
