# Git Attributes
# https://git-scm.com/docs/gitattributes

# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Source Code
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.jsonc text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.xml text eol=lf
*.svg text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Configuration
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
.prettierrc text eol=lf
.eslintrc text eol=lf

# Shell Scripts
*.sh text eol=lf
*.bash text eol=lf

# Binary Files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary

# Archives
*.7z binary
*.gz binary
*.tar binary
*.zip binary

# Exclude from exports
.gitattributes export-ignore
.gitignore export-ignore
.github/ export-ignore
.husky/ export-ignore
.vscode/ export-ignore
node_modules/ export-ignore
.wrangler/ export-ignore
*.log export-ignore
*.cache export-ignore

# Linguist (GitHub language detection)
*.md linguist-documentation
*.html linguist-detectable=true
*.css linguist-detectable=true
*.js linguist-detectable=true
docs/* linguist-documentation
scripts/* linguist-vendored=false
node_modules/* linguist-vendored
