# NPM Configuration
# https://docs.npmjs.com/cli/v10/configuring-npm/npmrc

# Use exact versions for dependencies
save-exact=true

# Prefer offline mode (use cache when possible)
prefer-offline=true

# Audit level
audit-level=moderate

# Engine strict (enforce Node.js version)
engine-strict=true

# Fund messages
fund=false

# Update notifier
update-notifier=false

# Progress
progress=true

# Loglevel
loglevel=warn
