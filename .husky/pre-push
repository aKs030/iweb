#!/bin/sh
# Husky pre-push hook

echo "🚀 Pre-push checks starting..."

# Skip for CI environments
if [ -n "$CI" ]; then
  echo "⏭️  Skipping in CI environment"
  exit 0
fi

# Clear caches
echo "🧹 Clearing caches..."
npm run -s clean:cache 2>/dev/null || true

# Run lint only (faster than full QA)
echo "🔍 Running linters..."
npm run lint

LINT_EXIT=$?

if [ $LINT_EXIT -ne 0 ]; then
  echo ""
  echo "❌ Lint checks failed"
  echo "💡 Run: npm run fix"
  echo ""
  read -p "❓ Push anyway? [y/N] " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    exit 1
  fi
fi

echo "✅ Pre-push checks passed!"
