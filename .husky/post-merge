#!/bin/sh
# Husky post-merge hook

echo "🔄 Post-merge checks..."

# Check if package.json or package-lock.json changed
CHANGED_FILES=$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD)

if echo "$CHANGED_FILES" | grep -qE "package(-lock)?.json"; then
  echo "📦 Dependencies changed, updating..."
  npm ci
  echo "✅ Dependencies updated!"
fi

# Clean caches after merge
echo "🧹 Cleaning caches..."
npm run -s clean:cache 2>/dev/null || true

echo "✅ Post-merge complete!"
